# Copy to .env and adjust. None of these are required for a minimal local run.

# ── Model gateway (Ollama) ────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_DEFAULT_MODEL=llama3.2

# ── Scheduler ─────────────────────────────────────────────────────────────────
# How often (seconds) to run the periodic healthcheck. Default: 300 (5 min).
# SCHEDULE_HEALTHCHECK=300

# ── Webhook adapter ───────────────────────────────────────────────────────────
# If set, POST /webhook/trigger requires: Authorization: Bearer <token>
# WEBHOOK_TOKEN=your-secret-token

# ── CLI adapter / clients ─────────────────────────────────────────────────────
# Base URL used by adapters/cli.py and Clawrunner. Default: http://localhost:8000
# AI_CORE_URL=http://localhost:8000
